#!/usr/bin/env bash
set -u

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/lvs"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}"
LOG="$STATE_DIR/lvs-login-preflight.log"
STAMP="$STATE_DIR/last-successful-update"
LOCK="$RUNTIME_DIR/lvs-login-preflight.lock"
WALLPAPER="/usr/share/backgrounds/lvs/lvs-background.jpg"

MAX_AGE_SECONDS=$((14 * 24 * 60 * 60))
NETWORK_TIMEOUT=90
TIME_TIMEOUT=60

mkdir -p "$STATE_DIR"

exec > >(tee -a "$LOG") 2>&1

echo "=============================================="
echo " Linux Validation Drive Initializing"
echo "=============================================="
echo
echo "[0/3] Applying desktop defaults..."

if [ -f "$WALLPAPER" ] && command -v plasma-apply-wallpaperimage >/dev/null 2>&1; then
    plasma-apply-wallpaperimage "$WALLPAPER" >/dev/null 2>&1 || true
fi

echo "Desktop defaults applied."
echo
echo "Please wait. Checking network, time/date sync, and update status..."
echo

exec 9>"$LOCK"
if ! flock -n 9; then
    echo "Another preflight is already running. Closing in 10 seconds..."
    sleep 10
    exit 0
fi

echo "[1/3] Waiting for network..."

network_ok=0
for i in $(seq 1 "$NETWORK_TIMEOUT"); do
    if ping -c 1 -W 2 ghcr.io >/dev/null 2>&1; then
        network_ok=1
        break
    fi
    sleep 1
done

if [ "$network_ok" -ne 1 ]; then
    echo
    echo "WARNING: Network/GHCR was not reachable."
    echo "Updates cannot be checked right now."
    echo "Continuing without update check in 30 seconds..."
    sleep 30
    exit 0
fi

echo "Network OK."
echo

echo "[2/3] Waiting for system time/date sync..."

time_ok=0
for i in $(seq 1 "$TIME_TIMEOUT"); do
    if timedatectl show -p NTPSynchronized --value 2>/dev/null | grep -q '^yes$'; then
        time_ok=1
        break
    fi
    sleep 1
done

if [ "$time_ok" -ne 1 ]; then
    echo
    echo "WARNING: Time/date sync was not confirmed."
    echo "Continuing anyway in 30 seconds..."
    sleep 30
fi

echo "Time/date check complete."
echo

echo "[3/3] Checking update age..."

now="$(date +%s)"
last=0

if [ -f "$STAMP" ]; then
    last="$(stat -c %Y "$STAMP" 2>/dev/null || echo 0)"
fi

if [ "$last" -gt 0 ]; then
    age="$((now - last))"
else
    age="$MAX_AGE_SECONDS"
fi

if [ "$age" -lt "$MAX_AGE_SECONDS" ]; then
    echo "Validation drive update check is recent enough."
    echo "No update required."
    echo
    echo "Closing automatically in 5 seconds..."
    sleep 5
    exit 0
fi

echo
echo "This validation drive has not successfully updated in 14+ days."
echo "Running Bazzite update now before testing."
echo
echo "Do not power off this system."
echo

if ujust update; then
    touch "$STAMP"
    echo
    echo "Update completed successfully."
    echo "Rebooting in 15 seconds so staged OS updates can apply..."
    sleep 15
    systemctl reboot
else
    echo
    echo "WARNING: Update failed."
    echo "Do not use this drive for new/unvalidated hardware unless approved."
    echo "Continuing in 60 seconds..."
    sleep 60
fi
